# Copy to .env for local development. .env is gitignored.

# Repository driver: "dynamo" (default), "memory", or "postgres"
DB_DRIVER=dynamo

# Neon Postgres connection string. Required when DB_DRIVER=postgres.
# Also required by scripts/migrate-postgres.ts and scripts/smoke-test-postgres.ts.
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require
